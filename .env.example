# Clock On/Off App - Environment Configuration
# =============================================
# This project supports TWO ways to configure Supabase credentials.
# NEVER commit actual credentials to version control.

# =============================================
# Option 1: config.js file (RECOMMENDED for GitHub Pages)
# =============================================
# Create a file named config.js in the same directory as index.html
# and load it BEFORE db.js:
#
#   <script src="config.js"></script>
#   <script src="db.js"></script>
#
# Contents of config.js:
#
#   window.SUPABASE_CONFIG = {
#     url: 'https://your-project-id.supabase.co',
#     anonKey: 'your-anon-public-key-here'
#   };
#

# =============================================
# Option 2: Edit db.js directly
# =============================================
# Open db.js and replace the fallback values at the top.
# This is the simplest method if you only have one deployment.
#

# =============================================
# Your Supabase Credentials
# =============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-key-here

# =============================================
# Security Notes
# =============================================
# - The anon key is safe to use in client-side code
# - Row-Level Security (RLS) policies protect your data
# - Never commit credentials to version control
# - config.js is already listed in .gitignore
#
